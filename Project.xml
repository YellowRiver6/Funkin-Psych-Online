<?xml version="1.0" encoding="utf-8"?>
<project>
	<!-- _________________________ Application Settings _________________________ -->
	<architecture exclude="armv7" if="ONLY_ARM64" />
	<architecture exclude="armeabi-v7a" if="ONLY_ARM64" />
	<architecture exclude="arm64" if="ONLY_ARMV7" />
	<architecture exclude="arm64-v8a" if="ONLY_ARMV7" />

	<app title="Friday Night Funkin': Psych Extended Online" file="PsychExtendedOnline" main="Main" packageName="com.arkoselabs.psychdextendedonline" package="com.arkoselabs.psychdextendedonline" company="ArkoseLabs" version="0.14.6" />
	<app if="mobile" title='Psych Extended Online' />

	<set name="APP_ID" value="0x0100f6c013bbc000" />
	<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB" />

	<app preloader="flixel.system.FlxPreloader" />
	<set name="SWF_VERSION" value="11.8" />
	
	<haxedef name="FLX_CNE_FORK" />
	<define name="HSC_ALLOWED" />
	<define name="SCRIPTING_ALLOWED" />
	<define name="TRANSLATIONS_ALLOWED" />

	<define name="MODS_ALLOWED" />
	<define name="HSCRIPT_ALLOWED" />
	<define name="LUA_ALLOWED" if="cpp" />
	<define name="ACHIEVEMENTS_ALLOWED" />
	<define name="DISCORD_ALLOWED" if="desktop || android" unless="hl" />
	<define name="VIDEOS_ALLOWED" if="desktop || mobile" />
	<define name="PSYCH_WATERMARKS" />
	<define name="TITLE_SCREEN_EASTER_EGG" />
	<define name="RAR_SUPPORTED" if="windows" unless="hl" />

	<window width="1280" height="720" fps="120" background="#000000" hardware="true" vsync="false" />
	<window if="html5" resizable="true" />
	<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" />
	<window if="mobile" orientation="landscape" fullscreen="true" resizable="false" allow-shaders="true" require-shaders="true" allow-high-dpi="true" />
	<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

	<set name="BUILD_DIR" value="export/debug" if="debug" />
	<set name="BUILD_DIR" value="export/release" unless="debug" />
	<set name="BUILD_DIR" value="export/32bit" if="32bits" />

	<classpath name="source_angle" if="ANGLE_BUILD" />
	<classpath name="source_default" unless="ANGLE_BUILD" />
	<classpath name="source" />
	<classpath name="library_extended" />

	<define name="PRELOAD_ALL" unless="web" />
	<define name="NO_PRELOAD_ALL" unless="PRELOAD_ALL" />

	<assets path="assets/fonts" />
	<assets path="assets/preload" rename="assets" exclude="*.ogg" if="web" />
	<assets path="assets/preload" rename="assets" exclude="*.mp3" unless="web" />
	<section if="TITLE_SCREEN_EASTER_EGG">
		<assets path="assets/secrets" rename="assets" exclude="*.ogg" if="web" />
		<assets path="assets/secrets" rename="assets" exclude="*.mp3" unless="web" />
	</section>

	<define name="CHECK_FOR_UPDATES" unless="LOCAL" />
	<library name="videos" preload="true" />
	<section if="PRELOAD_ALL">
		<library name="songs" preload="true" />
		<library name="shared" preload="true" />
		<library name="week_assets" preload="true" />
	</section>
	<section if="NO_PRELOAD_ALL">
		<library name="songs" preload="false" />
		<library name="shared" preload="false" />
		<library name="week_assets" preload="false" />
	</section>

	<assets path="assets/videos" library="videos" if="VIDEOS_ALLOWED" />
	<assets path="assets/songs" library="songs" exclude="*.ogg" if="web" />
	<assets path="assets/songs" library="songs" exclude="*.mp3" unless="web" />
	<assets path="assets/shared" library="shared" exclude="*.ogg" if="web" />
	<assets path="assets/shared" library="shared" exclude="*.mp3" unless="web" />
	<assets path="assets/week_assets" library="week_assets" rename="assets" exclude="*.ogg" if="web" />
	<assets path="assets/week_assets" library="week_assets" rename="assets" exclude="*.mp3" unless="web" />
	
	<section if="MODS_ALLOWED">
		<assets path='example_mods' rename='mods' embed='false' />
	</section>
	<assets path='art/readme.txt' rename='do NOT readme.txt' unless="mobile" />
	<assets path='art/run-server.bat' rename='run-server.bat' if="windows" />

	<define name="CRASH_HANDLER" if="desktop || mobile" />
	<assets path="mobile/storageModes.txt" if="mobile"/>

	<haxelib name="flixel" />
	<haxelib name="flixel-ui" />
	<haxelib name="flixel-addons" />
	<haxelib name="mobile-controls"/>
	<haxedef name="mobile_controls_file_support"/>
	<haxedef name="mobile_controls_allow_mouse_clicks" if="desktop"/>
		
	<haxelib name="linc_luajit" if="LUA_ALLOWED" />
	<haxelib name="hscript-improved" if="HSC_ALLOWED" />
	<haxelib name="SScript" if="HSCRIPT_ALLOWED" />
	<haxelib name="hxvlc" if="VIDEOS_ALLOWED" />
	<section if="desktop">
		<haxelib name="hxdiscord_rpc" if="DISCORD_ALLOWED" />
	</section>
	<haxelib name="tjson" />
	<haxelib name="colyseus" />
	<haxelib name="HtmlParser" />
	<haxelib name="UnRAR" />
	<haxelib name="away3d" />
	<haxelib name="json2object" />
	<haxelib name="hxjsonast" />
	<haxelib name="flxanimate" />
	<haxelib name="lumod" />
	<haxelib name="actuate" />
	<haxelib name="compiletime" />
	<haxelib name="funkin.vis" />
	<haxelib name="grig.audio" />
	<haxelib name="away3d" />
	<haxelib name="yagp" />
	<haxelib name="tink_await" />

	<haxedef name="interpretable" />
	<haxedef name="interpret_watch" />
	<haxedef name="openflPos" />
	<haxedef name="hscriptPos" />
	<haxelib name="hxcpp-debug-server" if="debug"/>
	<haxedef name="HXC_LIBVLC_LOGGING" if="VIDEOS_ALLOWED debug" />
	<haxedef name="LUMOD_HSCRIPT" />

	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
	<haxedef name="HXC_DEBUG_TRACE" if="debug" />
	<haxedef name="FLX_NO_DEBUG" />
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />
	<haxedef name="HXCPP_CHECK_POINTER" />
	<haxedef name="HXCPP_STACK_LINE" />
	<haxedef name="HXCPP_STACK_TRACE" />
	<haxedef name="HXCPP_CATCH_SEGV" />
	<haxedef name='no-deprecation-warnings' />
	<haxedef name="loop_unroll_max_cost" value="25" />
	<haxedef name="DISABLED_MACRO_SUPERLATIVE" if="android" />
	<haxeflag name="--macro" value="allowPackage('flash')" />
	<haxeflag name="--macro" value="include('my.pack')" />
	<haxeflag name="-D" value="HXCPP_DEBUGGER" if="debug"/>
	<haxeflag name="-debug" if="debug"/>

	<section if='debugmon'>
		<haxeflag name="--macro" value="addGlobalMetadata('online', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('states', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('flixel', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('backend', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('io', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('objects', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('psychlua', '@:build(online.backend.MonitorMacro.build())')" />
		<haxeflag name="--macro" value="addGlobalMetadata('llua', '@:build(online.backend.MonitorMacro.build())')" />
	</section>

	<certificate path="key.keystore" password="psychengine" alias="psychport" alias-password="psychengine" if="android" unless="debug" />
	<haxedef name="DISABLE_AUDIO_FOCUS" if="android" />
	<haxedef name="openfl_dpi_aware" />
	<haxedef name="message.reporting" value="pretty" />
	<define name="GLOBAL_SCRIPT" if="SCRIPTING_ALLOWED" />
	<define name="CUSTOM_CLASSES" unless="STRIPPED_COMPILE" />
	<haxedef name="HSCRIPT_ABSTRACT_SUPPORT" unless="STRIPPED_COMPILE" />

	<java path="source/mobile/android/" if="android" />
	<java path="mobile/android/" if="android" />

	<config:ios category_type="public.app-category.music-games" />
	<config:mac category_type="public.app-category.music-games" />

	<section unless="ANGLE_BUILD">
		<haxedef name="lime_use_old_deltatime" />
		<haxedef name="lime_disable_motion_sensors" />
	</section>

	<assets path='art/iconOG.png' rename='icon.png' if="linux" />
	<icon path="art/thumb-rect.png" if="mobile" />
	<section unless="mobile">
		<icon path="art/icon16.png" size='16'/>
		<icon path="art/icon32.png" size='32'/>
		<icon path="art/icon64.png" size='64'/>
		<icon path="art/iconOG.png" />
	</section>

	<!-- 全局开启IME支持（Windows+安卓通用） -->
<haxedef name="lime_text_input_compose" />
<haxedef name="openfl_enable_ime" />
<haxedef name="openfl_text_input_immersive" />

<!-- Android输入法完整配置 -->
<android>
    <manifest android:installLocation="auto">
        <uses-permission android:name="android.permission.INTERNET"/>
        <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
        <application android:hardwareAccelerated="true">
            <activity
                android:name=".MainActivity"
                android:configChanges="keyboard|keyboardHidden|orientation|screenSize"
                android:windowSoftInputMode="adjustResize|stateVisible">
            </activity>
        </application>
    </manifest>
</android>

</project>
